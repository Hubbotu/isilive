package-as: isiLive
enable-nolib-creation: no
manual-changelog:
  filename: CHANGELOG_RELEASE.md
  markup-type: markdown
ignore:
  - .github
  - .githooks
  - .vscode
  - .claude
  - .gitattributes
  - .editorconfig
  - .luacheckrc
  - .stylua.toml
  - .styluaignore
  - .luarocks
  - .gitignore
  - docs
  - README.md
  - AGENTS.md
  - CLAUDE.md
  - LICENSE
  - tools
  - testmodul
  - luacheck_output.txt
  - isiLive.png
  - isiLive_H_ui.png
  - isiLive_M2_ui.png
  - isiLive_M_ui.png
  - isiLive_V_ui.png
  - isiLive_screenshot.png
