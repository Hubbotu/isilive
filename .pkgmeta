package-as: isiLive
enable-nolib-creation: no
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
ignore:
  - .github
  - .githooks
  - .vscode
  - .gitattributes
  - .editorconfig
  - .luacheckrc
  - .stylua.toml
  - .styluaignore
  - .luarocks
  - .gitignore
  - ARCHITECTURE.md
  - USECASES.md
  - README.md
  - RELEASE.md
  - WARTUNG.md
  - TODO.md
  - TODO_RENAME.md
  - RULES.md
  - RULES_LOGIC.md
  - AGENTS.md
  - LICENSE
  - tools
  - testmodul
  - isiLive.png
  - isiLive_H_ui.png
  - isiLive_M_ui.png
  - isiLive_V_ui.png
  - isiLive_screenshot.png
